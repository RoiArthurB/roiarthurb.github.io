---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

const normalizePath = (path: string) => {
	const withoutBase = path.replace(basePath, '') || '/';
	if (withoutBase === '/') return '/';
	return withoutBase.replace(/\/+$/, '') || '/';
};

const pathname = normalizePath(Astro.url.pathname);
const hrefValue = typeof href === 'string' ? href : href?.toString() || '/';
const isExternal = /^(https?:|mailto:|tel:)/.test(hrefValue);
const normalizedHref = isExternal ? hrefValue : normalizePath(hrefValue);
const subpath = pathname.match(/[^\/]+/g);
const isActive = !isExternal && (normalizedHref === pathname || normalizedHref === '/' + (subpath?.[0] || ''));
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
