---
const today = new Date();
import {
  CONTACT,
  CV_URL,
  FOOTER_CREDIT,
  SITE_DESCRIPTION,
  SITE_TITLE,
  SOCIAL_LINKS,
} from '../consts';
import Search from './Search.astro';
import { url } from '../utils/paths';

const cvHref = CV_URL ? url(CV_URL) : null;
---

<footer class="site-footer">
    <div class="footer-content">
        <div class="footer-col brand-col">
            <h3>{SITE_TITLE}</h3>
            <p>
                {SITE_DESCRIPTION}
            </p>
            <div class="copyright">
                &copy; {today.getFullYear()} {SITE_TITLE}.<br/>All rights reserved.
            </div>
        </div>

        <div class="footer-col">
        <!-- 
            <h4>Quick Links</h4>
            <ul>
                <li><a href={url('/')}>Home</a></li>
                <li><a href={url('/publications')}>Publications</a></li>
                <li><a href={url('/projects')}>Projects</a></li>
                <li><a href={url('/team')}>Team</a></li>
                <li><a href={url('/blog')}>News</a></li>
                {cvHref && <li><a href={cvHref} target="_blank">Download CV</a></li>}
            </ul>
        -->
        </div>

        <div class="footer-col">
            <h4>Contact</h4>
            <address>
                {CONTACT.organization}<br/>
                {CONTACT.addressLines.map((line) => (
                    <>
                        {line}<br/>
                    </>
                ))}
            </address>
            <p style="margin-top: 1rem;">
                {CONTACT.emails.map((email) => (
                    <>
                        <a href={`mailto:${email}`} style="text-decoration: underline;">{email}</a><br/>
                    </>
                ))}
            </p>
        </div>

        <div class="footer-col">
            <h4>Connect</h4>
            <div class="social-links">
                {SOCIAL_LINKS.map((link) => (
                    <a
                        href={link.href}
                        target={link.href.startsWith('mailto:') ? undefined : '_blank'}
                        rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
                        aria-label={link.label}
                    >
                        {link.icon === 'scholar' && (
                            <svg fill="currentColor" viewBox="0 0 32 32" width="24" height="24" xmlns="http://www.w3.org/2000/svg"><path d="M14.573 2.729c-0.729 0.484-4.292 2.849-7.917 5.255s-6.589 4.396-6.589 4.422c0 0.026 0.182 0.146 0.406 0.266 0.224 0.13 3.797 2.109 7.953 4.411l7.542 4.193 0.193-0.099c0.109-0.052 2.891-1.641 6.188-3.521l5.99-3.427 0.036 10.599h3.557v-12.401l-4.615-3.094c-6.219-4.167-11.188-7.448-11.307-7.474-0.063-0.010-0.703 0.38-1.438 0.87zM7.141 22.177l0.016 2.672 8.828 5.292 8.891-5.339v-2.641c0-1.458-0.016-2.646-0.031-2.646-0.021 0-1.76 1.042-3.87 2.323l-4.406 2.661-0.578 0.339-1.755-1.052c-1.464-0.875-2.927-1.755-4.385-2.641l-2.672-1.615c-0.031-0.010-0.042 1.177-0.036 2.646z"></path></svg>
                        )}
                        {link.icon === 'email' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                        )}
                        {link.icon === 'website' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                        )}
                        {link.icon === 'github' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                        )}
                        {link.icon === 'linkedin' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                        )}
                        {link.icon === 'orcid' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>
                        )}
                        {link.icon === 'twitter' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
                        )}
                    </a>
                ))}
                    <a href='https://en.wikipedia.org/wiki/Piratbyr%C3%A5n#Kopimi' target='_blank' rel='noopener noreferrer' aria-label='Kopimi'>
                        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M 20.945312 7.027344 L 18.394531 8.761719 L 15.871094 7.058594 L 13.738281 8.484375 L 13.738281 2.125 L 10.765625 0.109375 L 7.824219 2.125 L 7.824219 8.484375 L 3.109375 5.320312 L 0.164062 7.304688 L 0.164062 14.90625 L 13.320312 23.84375 L 16.261719 21.828125 L 16.261719 18.351562 L 18.398438 16.898438 L 20.949219 18.636719 L 23.921875 16.648438 L 23.921875 9.050781 Z M 10.765625 0.632812 L 12.980469 2.121094 L 10.765625 3.609375 L 8.554688 2.121094 Z M 10.765625 4.109375 L 12.945312 5.570312 L 10.765625 7.089844 L 8.554688 5.601562 Z M 10.765625 7.554688 L 12.945312 9.042969 L 10.765625 10.53125 L 8.554688 9.042969 Z M 0.929688 7.304688 L 3.109375 5.8125 L 5.320312 7.300781 L 3.109375 8.792969 Z M 3.480469 9.042969 L 5.695312 7.554688 L 7.875 9.046875 L 5.660156 10.535156 Z M 6 10.78125 L 8.214844 9.292969 L 10.425781 10.78125 L 8.214844 12.269531 Z M 8.554688 12.519531 L 10.765625 11.03125 L 12.945312 12.492188 L 10.765625 13.976562 Z M 13.320312 15.714844 L 11.105469 14.222656 L 13.320312 12.734375 L 13.335938 12.746094 L 15.5 14.226562 Z M 15.839844 10.535156 L 13.660156 9.042969 L 15.871094 7.554688 L 18.054688 9.042969 Z M 20.945312 10.535156 L 18.765625 9.046875 L 20.945312 7.558594 L 23.160156 9.046875 Z M 20.945312 10.535156 "/>
                        </svg>
                    </a>
            </div>
            <div class="social-links" style="color: var(--color-text-muted); display: inline">
                <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="72px" height="72px" viewBox="0 0 72 72" version="1.1" fill="currentColor" stroke-width="0" fill="none" stroke-linecap="round" stroke-linejoin="round" >
                    <path d="M 2.742188 2.742188 L 2.742188 69.230469 L 69.230469 69.230469 L 69.230469 2.742188 Z M 5.273438 5.273438 L 24.0625 5.273438 L 24.0625 24.0625 L 5.273438 24.0625 Z M 26.59375 5.273438 L 45.378906 5.273438 L 45.378906 24.0625 L 26.59375 24.0625 Z M 47.910156 5.273438 L 66.699219 5.273438 L 66.699219 24.0625 L 47.910156 24.0625 Z M 35.984375 6.671875 C 31.574219 6.675781 28 10.253906 28 14.667969 C 27.996094 19.082031 31.570312 22.664062 35.984375 22.667969 C 38.109375 22.671875 40.144531 21.828125 41.644531 20.328125 C 43.148438 18.828125 43.988281 16.789062 43.988281 14.667969 C 43.988281 10.25 40.402344 6.667969 35.984375 6.671875 Z M 5.273438 26.59375 L 24.0625 26.59375 L 24.0625 45.378906 L 5.273438 45.378906 Z M 26.59375 26.59375 L 45.378906 26.59375 L 45.378906 45.378906 L 26.59375 45.378906 Z M 47.910156 26.59375 L 66.699219 26.59375 L 66.699219 45.378906 L 47.910156 45.378906 Z M 57.320312 28 C 52.910156 28.003906 49.335938 31.574219 49.332031 35.984375 C 49.328125 40.402344 52.902344 43.984375 57.320312 43.988281 C 61.734375 43.984375 65.308594 40.402344 65.304688 35.984375 C 65.300781 31.574219 61.730469 28.003906 57.320312 28 Z M 5.273438 47.910156 L 24.0625 47.910156 L 24.0625 66.699219 L 5.273438 66.699219 Z M 26.59375 47.910156 L 45.378906 47.910156 L 45.378906 66.699219 L 26.59375 66.699219 Z M 47.910156 47.910156 L 66.699219 47.910156 L 66.699219 66.699219 L 47.910156 66.699219 Z M 14.667969 49.332031 C 10.253906 49.332031 6.675781 52.90625 6.671875 57.320312 C 6.675781 61.730469 10.253906 65.304688 14.667969 65.304688 C 19.082031 65.308594 22.664062 61.734375 22.667969 57.320312 C 22.664062 52.902344 19.082031 49.328125 14.667969 49.332031 Z M 35.984375 49.332031 C 31.574219 49.335938 28.003906 52.910156 28 57.320312 C 28.003906 61.730469 31.574219 65.300781 35.984375 65.304688 C 40.402344 65.308594 43.984375 61.734375 43.988281 57.320312 C 43.984375 52.902344 40.402344 49.328125 35.984375 49.332031 Z M 57.320312 49.332031 C 52.910156 49.335938 49.335938 52.910156 49.332031 57.320312 C 49.335938 61.730469 52.910156 65.300781 57.320312 65.304688 C 61.730469 65.300781 65.300781 61.730469 65.304688 57.320312 C 65.300781 52.910156 61.730469 49.335938 57.320312 49.332031 Z M 57.320312 49.332031 "/>
                </svg>
            </div>
        </div>
    </div>
    <div class="footer-credit">
        Based on <a href={FOOTER_CREDIT.sourceUrl} target="_blank" rel="noopener noreferrer">{FOOTER_CREDIT.designerName} - Astro Scholar</a> design
    </div>
    <script is:inline async src="https://gc.zgo.at/count.js" data-goatcounter="https://arthurbrugiere.goatcounter.com/count"></script>
</footer>

<Search />

<dialog id="author-modal" class="author-modal">
    <button id="close-modal" class="close-btn" aria-label="Close modal">&times;</button>
    <div class="modal-flex">
        <img id="modal-avatar" src="" alt="Avatar" class="modal-avatar" />
        <div>
            <h3 id="modal-name"></h3>
            <span id="modal-title"></span>
            <span id="modal-role"></span>
        </div>
    </div>
    <p id="modal-bio"></p>
    <div id="modal-socials"></div>
</dialog>

<script>
    const avatarPalette = [
        { bg: '#DCEBFF', fg: '#1D4ED8' },
        { bg: '#DFF7E2', fg: '#166534' },
        { bg: '#FDE7D8', fg: '#C2410C' },
        { bg: '#F5E3FF', fg: '#7E22CE' },
        { bg: '#FFE3E3', fg: '#BE123C' },
        { bg: '#E3F7F5', fg: '#0F766E' },
    ];

    type Member = {
        id?: string;
        name: string;
        title?: string;
        role?: string;
        bio?: string;
        avatar?: string;
        website?: string;
        github?: string;
        linkedin?: string;
        google_scholar?: string;
        email?: string;
    };

    const getInitials = (name: string) => {
        const parts = (name || '')
            .split(/\s+/)
            .map((part: string) => part.replace(/[^A-Za-z]/g, ''))
            .filter(Boolean);

        if (parts.length === 0) return 'NA';
        if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
        return `${parts[0][0]}${parts[parts.length - 1][0]}`.toUpperCase();
    };

    const generateFallbackAvatar = (name: string) => {
        const safeName = name || 'Unknown';
        const initials = getInitials(safeName);
        const seed = Array.from(safeName).reduce((sum: number, char: string) => sum + char.charCodeAt(0), 0);
        const palette = avatarPalette[seed % avatarPalette.length];
        const svg = `
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" role="img" aria-label="${safeName}">
                <rect width="200" height="200" rx="100" fill="${palette.bg}" />
                <text x="50%" y="50%" dominant-baseline="central" text-anchor="middle" font-family="Atkinson, Arial, sans-serif" font-size="76" font-weight="700" letter-spacing="2" fill="${palette.fg}">${initials}</text>
            </svg>
        `.trim();

        return `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(svg)}`;
    };

    const modal = document.getElementById('author-modal') as HTMLDialogElement | null;
    const closeBtn = document.getElementById('close-modal');

    const modalAvatar = document.getElementById('modal-avatar') as HTMLImageElement | null;
    const modalName = document.getElementById('modal-name');
    const modalTitle = document.getElementById('modal-title');
    const modalRole = document.getElementById('modal-role');
    const modalBio = document.getElementById('modal-bio');
    const modalSocials = document.getElementById('modal-socials');

    const initModals = () => {
        const triggers = document.querySelectorAll('.author-modal-trigger');
        triggers.forEach(card => {
            if(card.hasAttribute('data-modal-initialized')) return;
            card.setAttribute('data-modal-initialized', 'true');
            card.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                
                const dataRaw = card.getAttribute('data-member');
                if(!dataRaw) return;
                const member = JSON.parse(dataRaw) as Member;
                
                if (modalName) modalName.textContent = member.name;
                if (modalTitle) modalTitle.textContent = member.title || '';
                if (modalRole) modalRole.textContent = member.role || '';
                if (modalBio) modalBio.textContent = member.bio || 'No description available.';

                if (modalAvatar) {
                    const fallbackAvatar = generateFallbackAvatar(member.name);
                    modalAvatar.onerror = () => {
                        modalAvatar.onerror = null;
                        modalAvatar.src = fallbackAvatar;
                    };
                    modalAvatar.src = member.id
                        ? `${import.meta.env.BASE_URL}avatars/${member.id}.png`
                        : (member.avatar || fallbackAvatar);
                    modalAvatar.style.display = 'block';
                }

                let socialHtml = '';
                if(member.website) socialHtml += `
                    <a href="${member.website}" target="_blank" aria-label="Website" class="social-icon-btn">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                    </a>`;
                if(member.github) socialHtml += `
                    <a href="${member.github}" target="_blank" aria-label="GitHub" class="social-icon-btn">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                    </a>`;
                if(member.linkedin) socialHtml += `
                    <a href="${member.linkedin}" target="_blank" aria-label="LinkedIn" class="social-icon-btn">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                    </a>`;
                if(member.google_scholar) socialHtml += `
                    <a href="${member.google_scholar}" target="_blank" aria-label="Google Scholar" class="social-icon-btn">
                        <svg fill="currentColor" viewBox="0 0 32 32" width="20" height="20" xmlns="http://www.w3.org/2000/svg"><path d="M14.573 2.729c-0.729 0.484-4.292 2.849-7.917 5.255s-6.589 4.396-6.589 4.422c0 0.026 0.182 0.146 0.406 0.266 0.224 0.13 3.797 2.109 7.953 4.411l7.542 4.193 0.193-0.099c0.109-0.052 2.891-1.641 6.188-3.521l5.99-3.427 0.036 10.599h3.557v-12.401l-4.615-3.094c-6.219-4.167-11.188-7.448-11.307-7.474-0.063-0.010-0.703 0.38-1.438 0.87zM7.141 22.177l0.016 2.672 8.828 5.292 8.891-5.339v-2.641c0-1.458-0.016-2.646-0.031-2.646-0.021 0-1.76 1.042-3.87 2.323l-4.406 2.661-0.578 0.339-1.755-1.052c-1.464-0.875-2.927-1.755-4.385-2.641l-2.672-1.615c-0.031-0.010-0.042 1.177-0.036 2.646z"></path></svg>
                    </a>`;
                if(member.email) socialHtml += `
                    <a href="mailto:${member.email}" aria-label="Email" class="social-icon-btn">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                    </a>`;
                if (modalSocials) modalSocials.innerHTML = socialHtml;

                document.body.style.overflow = 'hidden';
                if (modal) modal.showModal();
            });
        });
    }

    if(modal) {
        initModals();

        modal.addEventListener('close', () => {
            document.body.style.overflow = '';
        });

        if (closeBtn) {
            closeBtn.addEventListener('click', () => {
                modal.close();
            });
        }

        modal.addEventListener('click', (e) => {
            const dialogDimensions = modal.getBoundingClientRect()
            if (
                e.clientX < dialogDimensions.left ||
                e.clientX > dialogDimensions.right ||
                e.clientY < dialogDimensions.top ||
                e.clientY > dialogDimensions.bottom
            ) {
                modal.close();
            }
        });
    }
</script>

<style>
	.site-footer {
		background-color: var(--color-bg-offset);
		color: var(--color-text-main);
		padding: 4rem 1rem;
        margin-top: auto;
        transition: background-color 0.3s ease;
        position: relative;
        padding-bottom: 0.5% !important;
	}

    .site-footer::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent 0%, var(--color-border) 20%, var(--color-border) 80%, transparent 100%);
        opacity: 0.6;
    }

    .footer-content {
        max-width: var(--max-width);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 3rem;
    }
    .footer-col h3 {
        font-family: var(--font-serif);
        font-size: 1.5rem;
        margin-bottom: 1rem;
        color: var(--color-accent);
    }
    .footer-col h4 {
        font-family: var(--font-sans);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1.25rem;
        color: var(--color-text-main);
    }
    .footer-col ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .footer-col ul li {
        margin-bottom: 0.75rem;
    }
    .footer-col a {
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 0.2s;
    }
    .footer-col a:hover {
        color: var(--color-accent);
    }
    .brand-col p {
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin-bottom: 1.5rem;
    }
    .copyright {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        line-height: 1.5;
    }
    address {
        font-style: normal;
