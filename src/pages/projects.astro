---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import AuthorLink from '../components/AuthorLink.astro';
import projectsData from '../data/projects.json';
import { url } from '../utils/paths';

const projects = projectsData.sort((a, b) => b.year - a.year);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="Research Projects" />
		<style>
			.projects-section {
				max-width: var(--max-width);
				margin: 0 auto;
			}
			.projects-hero {
				text-align: center;
				margin-bottom: 4rem;
				padding: 2rem 0;
			}
			.projects-hero h1 {
				font-family: var(--font-serif);
				font-size: 3.2rem;
				margin: 0 0 1rem 0;
				color: var(--color-text-main);
				letter-spacing: -0.02em;
				line-height: 1.2;
			}
			.projects-hero p {
				font-size: 1.15rem;
				color: var(--color-text-muted);
				max-width: 700px;
				margin: 0 auto;
				line-height: 1.7;
			}
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 2.5rem;
				margin-bottom: 4rem;
			}
			.project-card {
				display: flex;
				flex-direction: column;
				background-color: var(--color-bg-offset);
				border: 1px solid var(--color-border);
				border-radius: 16px;
				overflow: hidden;
				transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
			}
			.project-card:hover {
				transform: translateY(-6px);
				box-shadow: var(--shadow-lg);
				border-color: var(--color-accent);
			}
			.project-image {
				position: relative;
				width: 100%;
				aspect-ratio: 16 / 9;
				overflow: hidden;
			}
			.project-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.6s ease;
			}
			.project-card:hover .project-image img {
				transform: scale(1.05);
			}
			.project-badge {
				position: absolute;
				top: 1rem;
				right: 1rem;
				padding: 0.35rem 0.8rem;
				background-color: var(--color-bg-header);
				color: var(--color-text-main);
				font-size: 0.7rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				border-radius: 20px;
				backdrop-filter: blur(8px);
				box-shadow: 0 2px 8px rgba(0,0,0,0.1);
				z-index: 10;
			}
			.project-content-wrapper {
				display: flex;
				flex-direction: column;
				padding: 1.75rem;
				flex: 1;
			}
			.project-year {
				font-size: 0.75rem;
				color: var(--color-accent);
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-bottom: 0.5rem;
			}
			.project-card h3 {
				font-family: var(--font-serif);
				font-size: 1.4rem;
				margin: 0 0 1rem 0;
				line-height: 1.3;
				color: var(--color-text-main);
			}
			.project-card h3 a {
				color: inherit;
				text-decoration: none;
			}
			.project-description {
				color: var(--color-text-muted);
				font-size: 0.95rem;
				line-height: 1.6;
				margin-bottom: 1.5rem;
				flex: 1;
			}
			.project-meta {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.85rem;
				margin-bottom: 1.25rem;
				flex-wrap: wrap;
				padding-top: 1rem;
				border-top: 1px solid var(--color-border);
			}
			.meta-label {
				font-weight: 600;
				color: var(--color-text-muted);
			}
			.author-names {
				color: var(--color-text-main);
				font-weight: 500;
			}
			.read-more {
				display: inline-flex;
				align-items: center;
				font-size: 0.9rem;
				color: var(--color-accent);
				text-decoration: none;
				font-weight: 600;
				transition: gap 0.2s ease;
				gap: 0.25rem;
			}
			.read-more:hover {
				gap: 0.5rem;
			}
			@media (max-width: 768px) {
				.projects-hero h1 { font-size: 2.5rem; }
				.projects-grid { gap: 2rem; }
				.project-content-wrapper { padding: 1.5rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="projects-section">
			<div class="projects-hero">
				<h1>Research Projects</h1>
				<p>Landmark philosophical investigations that have fundamentally shaped the course of Western intellectual history.</p>
			</div>
			
			<div class="projects-grid">
				{projects.length > 0 ? projects.map((project) => (
					<article class="project-card">
						<div class="project-image">
							<img
								src={url(`/projects/${project.id}.png`)}
								alt={project.title}
							/>
							<span class="project-badge">{project.status}</span>
						</div>

						<div class="project-content-wrapper">
							<div class="project-header">
								<span class="project-year">{project.year > 0 ? project.year : 'Classical'}</span>
								<h3>
									{project.link ? (
										<a href={project.link} target="_blank">{project.title}</a>
									) : (
										project.title
									)}
								</h3>
							</div>
							
							<p class="project-description">{project.description}</p>
							
							{project.authors && project.authors.length > 0 && (
								<div class="project-meta">
									<span class="meta-label">By:</span>
									<span class="author-names">
										{project.authors.map((authorId, i) => (
											<span>
												<AuthorLink nameOrSlug={authorId} />
												{i < project.authors!.length - 1 ? ', ' : ''}
											</span>
										))}
									</span>
								</div>
							)}

							{project.link && (
								<a href={project.link} target="_blank" class="read-more">
									Read More &rarr;
								</a>
							)}
						</div>
					</article>
				)) : (
                    <p>No projects found in <code>src/data/projects.json</code>.</p>
                )}
			</div>
		</main>
		<Footer />
	</body>
</html>
