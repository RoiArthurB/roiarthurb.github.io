---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import softwareData from '../data/software.json';

const startYear = (since: number | number[]) => Array.isArray(since) ? since[0] : since;
const formatSince = (since: number | number[]) =>
  Array.isArray(since) ? `${since[0]}–${since[1]}` : `Since ${since}`;

const software = [...softwareData].sort((a, b) => startYear(b.since) - startYear(a.since));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Software | ${SITE_TITLE}`} description="Open-source software contributions" />
		<style>
			.software-section {
				max-width: var(--max-width);
				margin: 0 auto;
			}
			.software-hero {
				text-align: center;
				margin-bottom: 4rem;
				padding: 2rem 0;
			}
			.software-hero h1 {
				font-family: var(--font-serif);
				font-size: 3.2rem;
				margin: 0 0 1rem 0;
				color: var(--color-text-main);
				letter-spacing: -0.02em;
				line-height: 1.2;
			}
			.software-hero p {
				font-size: 1.15rem;
				color: var(--color-text-muted);
				max-width: 700px;
				margin: 0 auto;
				line-height: 1.7;
			}
			.software-list {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				margin-bottom: 4rem;
			}
			.software-card {
				display: flex;
				gap: 1.75rem;
				align-items: flex-start;
				background-color: var(--color-bg-offset);
				border: 1px solid var(--color-border);
				border-radius: 16px;
				padding: 1.75rem;
				transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
			}
			.software-card:hover {
				transform: translateY(-4px);
				box-shadow: var(--shadow-lg);
				border-color: var(--color-accent);
			}
			.software-icon {
				flex-shrink: 0;
				width: 56px;
				height: 56px;
				border-radius: 12px;
				background-color: var(--color-accent);
				display: flex;
				align-items: center;
				justify-content: center;
				font-family: var(--font-serif);
				font-size: 1.5rem;
				font-weight: 700;
				color: #fff;
				letter-spacing: -0.02em;
			}
			.software-icon--image {
				background-color: transparent;
			}
			.software-icon img {
				width: 100%;
				height: 100%;
				object-fit: contain;
				border-radius: 12px;
			}
			.software-body {
				flex: 1;
				min-width: 0;
			}
			.software-header {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 0.4rem;
				flex-wrap: wrap;
			}
			.software-title {
				font-family: var(--font-serif);
				font-size: 1.35rem;
				margin: 0;
				line-height: 1.3;
				color: var(--color-text-main);
			}
			.software-title a {
				color: inherit;
				text-decoration: none;
			}
			.software-title a:hover {
				color: var(--color-accent);
			}
			.role-badge {
				flex-shrink: 0;
				padding: 0.25rem 0.75rem;
				background-color: var(--color-bg-header);
				border: 1px solid var(--color-border);
				color: var(--color-accent);
				font-size: 0.7rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				border-radius: 20px;
				white-space: nowrap;
			}
			.software-meta {
				font-size: 0.8rem;
				color: var(--color-text-muted);
				margin-bottom: 0.85rem;
				display: flex;
				align-items: center;
				gap: 0.5rem;
				flex-wrap: wrap;
			}
			.meta-since {
				font-weight: 600;
			}
			.meta-dot {
				opacity: 0.4;
			}
			.meta-tag {
				background-color: var(--color-bg-header);
				border: 1px solid var(--color-border);
				border-radius: 4px;
				padding: 0.1rem 0.4rem;
				font-size: 0.72rem;
				font-weight: 500;
			}
			.software-description {
				color: var(--color-text-muted);
				font-size: 0.95rem;
				line-height: 1.6;
				margin-bottom: 1.1rem;
			}
			.software-links {
				display: flex;
				gap: 1.25rem;
				flex-wrap: wrap;
			}
			.software-link {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				font-size: 0.875rem;
				color: var(--color-accent);
				text-decoration: none;
				font-weight: 600;
				transition: gap 0.2s ease;
			}
			.software-link:hover {
				gap: 0.55rem;
			}
			.software-link svg {
				flex-shrink: 0;
			}
			@media (max-width: 768px) {
				.software-hero h1 { font-size: 2.5rem; }
				.software-card { gap: 1.25rem; padding: 1.25rem; }
				.software-icon { width: 48px; height: 48px; font-size: 1.25rem; }
			}
			@media (max-width: 480px) {
				.software-card { flex-direction: column; gap: 1rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="software-section">
			<div class="software-hero">
				<h1>Open Source</h1>
				<p>Software projects and platforms I actively contribute to — ongoing work that lives outside the scope of any single research project.</p>
			</div>

			{software.length > 0 ? (
				<div class="software-list">
					{software.map((item) => (
						<article class="software-card">
							<div class={`software-icon${item.logo ? ' software-icon--image' : ''}`} aria-hidden="true">
								{item.logo
									? <img src={item.logo} alt={item.title} />
									: item.title.charAt(0)
								}
							</div>

							<div class="software-body">
								<div class="software-header">
									<h2 class="software-title">
										{item.link ? (
											<a href={item.link} target="_blank" rel="noopener noreferrer">{item.title}</a>
										) : (
											item.github ? (
												<a href={item.github} target="_blank" rel="noopener noreferrer">{item.title}</a>
											) : (
												item.title
											)
										)}
									</h2>
									<span class="role-badge">{item.role}</span>
								</div>

								<div class="software-meta">
									<span class="meta-since">{formatSince(item.since)}</span>
									{item.tags && item.tags.length > 0 && (
										<>
											<span class="meta-dot">·</span>
											{item.tags.map((tag) => (
												<span class="meta-tag">{tag}</span>
											))}
										</>
									)}
								</div>

								<p class="software-description">{item.description}</p>

								<div class="software-links">
									{item.link && (
										<a href={item.link} target="_blank" rel="noopener noreferrer" class="software-link">
											<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
											Website &rarr;
										</a>
									)}
									{item.github && (
										<a href={item.github} target="_blank" rel="noopener noreferrer" class="software-link">
											<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
											GitHub &rarr;
										</a>
									)}
								</div>
							</div>
						</article>
					))}
				</div>
			) : (
				<p>No entries found in <code>src/data/software.json</code>.</p>
			)}
		</main>
		<Footer />
	</body>
</html>
