---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { url } from '../utils/paths';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const groupedPosts = posts.reduce((acc, post) => {
    const date = new Date(post.data.pubDate);
    const year = date.getFullYear();
    const month = date.toLocaleString('default', { month: 'long' });

    if (!acc[year]) acc[year] = {};
    if (!acc[year][month]) acc[year][month] = [];

    acc[year][month].push(post);
    return acc;
}, {} as Record<number, Record<string, typeof posts>>);

const years = Object.keys(groupedPosts).map(Number).sort((a, b) => b - a);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Archive | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
        <style>
            .archive-year {
                margin-top: 3rem;
                margin-bottom: 1.5rem;
                font-size: 2rem;
                color: var(--color-text-main);
                border-bottom: 2px solid var(--color-border);
                padding-bottom: 0.5rem;
            }
            .archive-month {
                margin-top: 2rem;
                margin-bottom: 1rem;
                font-size: 1.5rem;
                color: var(--color-text-muted);
            }
            .archive-list {
                list-style: none;
                padding: 0;
                margin: 0;
            }
            .archive-item {
                display: flex;
                align-items: baseline;
                gap: 1rem;
                margin-bottom: 0.75rem;
            }
            .archive-date {
                color: var(--color-text-muted);
                font-family: var(--font-mono);
                font-size: 0.9rem;
                min-width: 6rem;
            }
            .archive-link {
                color: var(--color-text-main);
                text-decoration: none;
                font-size: 1.1rem;
                font-weight: 500;
                transition: color 0.2s;
            }
            .archive-link:hover {
                color: var(--color-accent);
            }

            @media (max-width: 600px) {
                .archive-item {
                    flex-direction: column;
                    gap: 0.25rem;
                    margin-bottom: 1.25rem;
                }
                .archive-date {
                    font-size: 0.85rem;
                }
            }
        </style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Archive</h1>
            <p style="margin-bottom: 2rem; color: var(--color-text-muted);">
                A chronological list of all published blog posts.
            </p>

            <div class="archive-container">
                {years.map((year) => (
                    <div class="year-section">
                        <h2 class="archive-year">{year}</h2>

                        {Object.entries(groupedPosts[year]).map(([month, monthPosts]) => (
                            <div class="month-section">
                                <h3 class="archive-month">{month}</h3>
                                <ul class="archive-list">
                                    {monthPosts.map((post) => (
                                        <li class="archive-item">
                                            <span class="archive-date">
                                                <FormattedDate date={post.data.pubDate} />
                                            </span>
                                            <a href={url(`/blog/${post.id}/`)} class="archive-link">
                                                {post.data.title}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        ))}
                    </div>
                ))}

                {posts.length === 0 && (
                    <p style="text-align: center; color: var(--color-text-muted);">
                        No blog posts found.
                    </p>
                )}
            </div>
		</main>
		<Footer />
	</body>
</html>
